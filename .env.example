# Memory Layer Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# App
APP_NAME=memory-layer
APP_ENV=development
DEBUG=true
SECRET_KEY=          # Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"

# JWT
JWT_SECRET_KEY=      # Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# Fernet encryption key for API key storage (JSON list)
FERNET_KEYS=         # Generate: python -c "from cryptography.fernet import Fernet; print('[\"' + Fernet.generate_key().decode() + '\"]')"

# Neo4j
# Local:  bolt://localhost:7687
# Aura:   neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# Rate Limiting
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_INGEST=20/minute

# Sleep Cycle (consolidation runs at this time in production only)
SLEEP_CRON_HOUR=2
SLEEP_CRON_MINUTE=0

# Logging
LOG_LEVEL=INFO
